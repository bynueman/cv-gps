# Path is relative to prisma/schema.prisma (so "../data/gps.db" = repo
# root's data/gps.db) — but this ONLY works when the app runs with its
# working directory unchanged (VPS via `next start`, or local `next dev`).
# On cPanel/Passenger deploys (output: "standalone"), server.js calls
# process.chdir() to its own directory, so a relative path silently
# points at the wrong file. On those hosts, use an ABSOLUTE path instead:
#   DATABASE_URL="file:/home/youruser/gpsfood/data/gps.db"
DATABASE_URL="file:../data/gps.db"

# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=
# Full URL of the deployed site, no trailing slash
NEXTAUTH_URL=

# Public site URL used for metadataBase, sitemap, canonical URLs, OG tags
NEXT_PUBLIC_SITE_URL="https://gpsfood.id"
